# Server
SERVER_PORT=4000
NODE_ENV=development

# Database
DATABASE_URL=postgresql://tolovelist:tolovelist@localhost:5432/tolovelist?schema=public

# JWT
JWT_SECRET=change-this-to-a-secure-random-string
JWT_REFRESH_SECRET=change-this-to-another-secure-random-string
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# AI Providers
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
OPENROUTER_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434

# Default AI Provider
AI_PROVIDER=openai

# Client
VITE_API_URL=http://localhost:4000/api
